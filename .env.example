# ---- Narrative Watchtower environment ----
# Copy to .env.local and fill in. The DEPLOYED app needs NO runtime secrets —
# all intelligence is precomputed and bundled. These are for the OFFLINE pipeline
# and the optional live Copilot only.

# MongoDB (READ-ONLY source of raw scraped data). Used only by offline scripts.
MONGODB_URI="mongodb://user:pass@host:port/db?authSource=admin"
MONGODB_DB=""

# Optional: enable LIVE Analyst Copilot synthesis for arbitrary questions.
# Without it, the Copilot uses hybrid retrieval + a precomputed grounded cache.
ANTHROPIC_API_KEY=""
COPILOT_MODEL="claude-sonnet-5"

# Optional: override the local embedding model (default: Xenova/multilingual-e5-small).
EMBED_HF_MODEL="Xenova/multilingual-e5-small"
